{
  "profiles": {
    "edge-baseline": {
      "description": "Single edge node, baseline performance without lossy network",
      "benchmarks": {
        "http1-passthrough": {
          "description": "HTTP/1.1 pass-through traffic",
          "concurrency": 24,
          "min_throughput_rps": 900,
          "max_latency_p50_ms": 50,
          "max_latency_p95_ms": 150,
          "max_latency_p99_ms": 300,
          "max_error_rate": 0.01,
          "expected_status_codes": [200],
          "error_budget_pct": 1
        },
        "http1-challenge": {
          "description": "HTTP/1.1 with challenge requests",
          "concurrency": 12,
          "min_throughput_rps": 300,
          "max_latency_p50_ms": 100,
          "max_latency_p95_ms": 300,
          "max_latency_p99_ms": 500,
          "max_error_rate": 0.02,
          "expected_status_codes": [200, 429],
          "error_budget_pct": 2
        },
        "http2-passthrough": {
          "description": "HTTP/2 pass-through traffic",
          "concurrency": 24,
          "min_throughput_rps": 1200,
          "max_latency_p50_ms": 40,
          "max_latency_p95_ms": 120,
          "max_latency_p99_ms": 250,
          "max_error_rate": 0.01,
          "expected_status_codes": [200],
          "error_budget_pct": 1
        },
        "http3-passthrough": {
          "description": "HTTP/3 pass-through traffic",
          "concurrency": 24,
          "min_throughput_rps": 1100,
          "max_latency_p50_ms": 45,
